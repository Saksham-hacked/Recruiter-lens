# =============================================================================
# Template for the SERVER-SIDE .env (deploy/.env). Copy this to `.env` in this
# same folder ON THE EC2 SERVER and fill in real values. Never commit the real
# .env — it's gitignored.
#
#   cp .env.example .env   &&   nano .env
# =============================================================================

# ---- Deploy values (used by docker-compose.prod.yml + Caddy) ----------------
IMAGE=ghcr.io/<your-github-username>/recruiter-lens-backend
DOMAIN=<your-subdomain>.duckdns.org
ACME_EMAIL=you@example.com

# ---- App secrets (same set your local .env already has) ---------------------
PORT=3000
API_KEY=<long-random-secret>

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# IMPORTANT: this must be the HTTPS URL now, not localhost:
ZOHO_REDIRECT_URI=https://<your-subdomain>.duckdns.org/oauth/callback
ZOHO_BASE_URL=https://recruit.zoho.in/recruit/v2
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in/oauth/v2

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
